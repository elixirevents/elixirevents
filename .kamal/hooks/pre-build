#!/bin/sh
set -eu

# Generates priv/data/.changed_files listing YAML files changed in HEAD's
# merge commit. Copied into the image via `COPY priv priv` and consumed by
# bin/migrate on boot via ElixirEvents.Import.Sync.

MANIFEST_PATH="priv/data/.changed_files"
mkdir -p "$(dirname "$MANIFEST_PATH")"

git diff --name-only HEAD~1 HEAD -- priv/data/ | grep '\.yml$' > "$MANIFEST_PATH" || true

if [ -s "$MANIFEST_PATH" ]; then
  echo "[pre-build] Changed data files:"
  sed 's/^/  /' "$MANIFEST_PATH"
else
  echo "[pre-build] No priv/data/ changes in HEAD."
fi
